## ─── Server-side LLM proxy (optional) ─────────────────
# When enabled, the report's AI workbench routes calls through /api/llm
# using the keys below — users don't need to bring their own keys.
VITE_LLM_PROXY_ENABLED=false
VITE_LLM_PROXY_URL=/api/llm

# Configure these in the hosting platform when VITE_LLM_PROXY_ENABLED=true.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=


## ─── W11 — Anonymous benchmark aggregation (optional) ──
# When enabled, opted-in users (off by default) submit anonymous activity
# stats — answer length, quiz time/accuracy, roleplay style label — to
# /api/benchmark. Aggregated percentiles replace the static N=84 cohort
# in the report's "익명 비교" section.
#
# PRIVACY: api/benchmark.js validates and accepts only numeric/categorical
# fields. Names, profile fields, and free-text answers are NEVER sent or
# stored. See top-of-file docstring in api/benchmark.js.
VITE_BENCHMARK_ENABLED=false
VITE_BENCHMARK_ENDPOINT=/api/benchmark

# Optional production storage: Vercel KV / Upstash. When these env vars
# are set, api/benchmark.js automatically uses KV instead of in-memory.
# Without them, snapshots persist only within a single warm serverless
# instance — fine for demos, not for multi-instance production.
KV_REST_API_URL=
KV_REST_API_TOKEN=
